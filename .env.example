VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Optional: GitHub → Actions → your ingest workflow → … → copy permalink to manual runs
VITE_GITHUB_ACTIONS_INGEST_URL=
# Optional: HTTPS URL to your official logo (e.g. from CDN); falls back to typographic wordmark
VITE_BRAND_LOGO_URL=
# Optional: must match Netlify env INGEST_TRIGGER_SECRET if you set that (never use service_role here)
VITE_INGEST_TRIGGER_SECRET=
# Optional: full URL to ingest-background function if not same-origin (e.g. local dev hitting deployed function)
VITE_NETLIFY_INGEST_URL=

# Ingest retention (CLI + Netlify function): default 60 days
# FEED_RETENTION_DAYS=60
